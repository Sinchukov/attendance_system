generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEACHER
}

enum AttendanceStatus {
  PENDING
  PRESENT
  LATE
  ABSENT
  EXCUSED
}

enum LessonType {
  LECTURE
  PRACTICE
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())

  teacher Teacher?
}

enum AttendanceEventType {
  CHECK_IN_SUCCESS
  CHECK_OUT_SUCCESS

  DUPLICATE_CHECK_IN
  DUPLICATE_CHECK_OUT

  SPAM_DETECTED

  NO_ACTIVE_SESSION

  STUDENT_NOT_FOUND
  DEVICE_NOT_FOUND

  INVALID_SESSION
}

model AttendanceAuditLog {
  id Int @id @default(autoincrement())

  cardNo String

  deviceSerial String

  eventType AttendanceEventType

  message String?

  createdAt DateTime @default(now())

  studentId Int?

  lessonSessionId Int?

  attendanceId Int?

  deviceId Int?

  student Student? @relation(fields: [studentId], references: [id])

  lessonSession LessonSession? @relation(fields: [lessonSessionId], references: [id])

  attendance Attendance? @relation(fields: [attendanceId], references: [id])

  device Device? @relation(fields: [deviceId], references: [id])
}

model Teacher {
  id        Int      @id @default(autoincrement())
  fullName  String
  cardNo    String?  @unique
  userId    Int      @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  scheduleTemplates ScheduleTemplate[]
  sessions          LessonSession[]
  attendanceLogs    AttendanceChangeLog[]
}

model Subject {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  scheduleTemplates ScheduleTemplate[]
  sessions          LessonSession[]

  subdivisions SubjectSubdivision[]
}

model SubjectSubdivision {
  id Int @id @default(autoincrement())

  name String // "1ПГ"

  subjectId Int
  groupId   Int

  createdAt DateTime @default(now())

  subject Subject @relation(fields: [subjectId], references: [id])

  group AcademicGroup @relation(fields: [groupId], references: [id])

  students SubjectSubdivisionStudent[]

  scheduleTemplates ScheduleTemplate[]
  sessions          LessonSession[]

  @@unique([subjectId, groupId, name])
}

model SubjectSubdivisionStudent {
  id Int @id @default(autoincrement())

  subdivisionId Int
  studentId     Int

  subdivision SubjectSubdivision @relation(fields: [subdivisionId], references: [id])

  student Student @relation(fields: [studentId], references: [id])

  @@unique([subdivisionId, studentId])
}

model AcademicGroup {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  students Student[]

  scheduleTemplates ScheduleTemplate[]
  sessions          LessonSession[]

  subjectSubdivisions SubjectSubdivision[]
}

model Student {
  id            Int    @id @default(autoincrement())
  fullName      String
  studentCardNo String @unique

  groupId Int

  createdAt DateTime @default(now())

  group AcademicGroup @relation(fields: [groupId], references: [id])

  attendances Attendance[]

  subjectSubdivisions SubjectSubdivisionStudent[]
  auditLogs           AttendanceAuditLog[]
}

model Room {
  id   Int    @id @default(autoincrement())
  name String @unique

  devices           Device[]
  scheduleTemplates ScheduleTemplate[]
  sessions          LessonSession[]
}

model Device {
  id Int @id @default(autoincrement())

  serialNumber   String                @unique
  roomId         Int
  attendanceLogs AttendanceChangeLog[]
  createdAt      DateTime              @default(now())
  auditLogs      AttendanceAuditLog[]
  room           Room                  @relation(fields: [roomId], references: [id])
}

model PairTime {
  id Int @id @default(autoincrement())

  pairNumber Int @unique

  startTime String
  endTime   String

  scheduleTemplates ScheduleTemplate[]
  sessions          LessonSession[]
}

model ScheduleTemplate {
  id Int @id @default(autoincrement())

  weekday WeekDay

  lessonType LessonType

  subjectId  Int
  teacherId  Int
  roomId     Int
  pairTimeId Int

  groupId Int

  subdivisionId Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  subject Subject @relation(fields: [subjectId], references: [id])

  teacher Teacher @relation(fields: [teacherId], references: [id])

  room Room @relation(fields: [roomId], references: [id])

  pairTime PairTime @relation(fields: [pairTimeId], references: [id])

  group AcademicGroup @relation(fields: [groupId], references: [id])

  subdivision SubjectSubdivision? @relation(fields: [subdivisionId], references: [id])

  sessions LessonSession[]
}

model LessonSession {
  id Int @id @default(autoincrement())

  lessonDate DateTime

  lessonType LessonType

  subjectId  Int
  teacherId  Int
  roomId     Int
  pairTimeId Int

  groupId Int

  subdivisionId Int?

  templateId Int?

  isCancelled Boolean @default(false)

  cancellationReason String?

  createdAt DateTime @default(now())

  subject Subject @relation(fields: [subjectId], references: [id])

  teacher Teacher @relation(fields: [teacherId], references: [id])

  room Room @relation(fields: [roomId], references: [id])

  pairTime PairTime @relation(fields: [pairTimeId], references: [id])

  group AcademicGroup @relation(fields: [groupId], references: [id])

  subdivision SubjectSubdivision? @relation(fields: [subdivisionId], references: [id])

  template ScheduleTemplate? @relation(fields: [templateId], references: [id])

  attendances Attendance[]
  auditLogs   AttendanceAuditLog[]
}

model Attendance {
  id Int @id @default(autoincrement())

  studentId       Int
  lessonSessionId Int

  status AttendanceStatus

  checkIn DateTime?
  comment String?
  isManualEdited Boolean @default(false)

  createdAt DateTime @default(now())
  
  student Student @relation(fields: [studentId], references: [id])

  lessonSession LessonSession @relation(fields: [lessonSessionId], references: [id])

  changeLogs AttendanceChangeLog[]
  auditLogs  AttendanceAuditLog[]

  @@unique([studentId, lessonSessionId])
}

model AttendanceChangeLog {
  id Int @id @default(autoincrement())

  attendanceId Int

  teacherId Int?

  oldStatus AttendanceStatus?

  newStatus AttendanceStatus

  action String

  details String?

  deviceId Int?

  createdAt DateTime @default(now())

  attendance Attendance @relation(fields: [attendanceId], references: [id])

  teacher Teacher? @relation(fields: [teacherId], references: [id])

  device Device? @relation(fields: [deviceId], references: [id])
}